# Get your App ID from https://dashboard.privy.io
VITE_PRIVY_APP_ID=clxxxxxxxxxx

# AVNU Paymaster API key for sponsored (gasless) transactions
# https://portal.avnu.fi/
VITE_PAYMASTER_API_KEY=

# Your backend URL that returns signer context for Privy users.
# POST with Authorization: Bearer <accessToken> must return { walletId, publicKey, serverUrl }
VITE_SIGNER_CONTEXT_API=https://your-api.example/signer-context
