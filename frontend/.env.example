# ── Privy ──────────────────────────────────────────────────────────────
# Get your App ID from https://dashboard.privy.io
VITE_PRIVY_APP_ID=clxxxxxxxxxx

# ── AVNU Paymaster ──────────────────────────────────────────────────────
# Sponsored (gasless) transactions. Get key from https://portal.avnu.fi/
VITE_PAYMASTER_API_KEY=

# ── Backend: signer context ─────────────────────────────────────────────
# POST with Authorization: Bearer <accessToken> → { walletId, publicKey, serverUrl }
VITE_SIGNER_CONTEXT_API=https://your-api.example/signer-context

# ── Backend: member address resolver ───────────────────────────────────
# POST { email } → { address: "0x…" }  (maps Privy email to Starknet address)
# If empty, owner must paste the member's 0x… address directly.
VITE_RESOLVE_MEMBER_API=https://your-api.example/resolve-member

# ── Cairo contract ──────────────────────────────────────────────────────
# SpendingVault address after `scarb build` + deploy to Sepolia.
VITE_VAULT_ADDRESS=0x

# USDC ERC20 address on Starknet Sepolia
VITE_USDC_ADDRESS=0x053c91253bc9682c04929ca02ed00b3e423f6710d2ee7e0d5ebb06f3ecf368a8

# ── Starknet RPC (optional override) ────────────────────────────────────
# Defaults to public Blast API endpoint if not set.
VITE_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_8
